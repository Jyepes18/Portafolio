---
import experience from "../data/experience.json";
import projects from "../data/projects.json";
import education from "../data/education.json";
---

<section class="container" id="experience">
  <div class="row">
    <div class="col-lg-10">

      <h2 class="fw-bold mb-5 text-light">
        Experiencia laboral
      </h2>

      <div class="timeline">
        {
          experience.map((job) => (
            <article class="timeline-item mb-5">
              <span class="dot"></span>

              <div class="card bg-dark border-secondary text-light shadow-sm">
                <div class="card-body">

                  <small class="text-secondary">
                    {job.period}
                  </small>

                  <h4 class="mt-2 mb-1">
                    {job.company}
                  </h4>

                  <h6 class="text-primary mb-3">
                    {job.position}
                  </h6>

                  <p class="mb-0">
                    {job.description}
                  </p>

                </div>
              </div>
            </article>
          ))
        }
      </div>

    </div>
  </div>
</section>

<section class="projects py-5" id="projects">

    <h2 class="fw-bold text-light mb-5">
        Proyectos
    </h2>

    {
        projects.map((project) => (

            <article class="card bg-dark border-secondary text-light shadow mb-4">

                <div class="row g-0 align-items-center">

                    <!-- Imagen -->
                    <div class="col-lg-4">

                        <img
                            src={project.image}
                            alt={project.title}
                            class="project-image"
                        />

                    </div>

                    <!-- Información -->
                    <div class="col-lg-8">

                        <div class="card-body">

                            <h3 class="card-title">
                                {project.title}
                            </h3>

                            <div class="mb-3">

                                {
                                    project.technologies.map((tech) => (

                                        <span class="badge bg-primary me-2 mb-2">
                                            {tech}
                                        </span>

                                    ))
                                }

                            </div>

                            <p class="card-text">
                                {project.description}
                            </p>

                            <div class="d-flex gap-3 mt-4">

                                <a
                                    href={project.github}
                                    target="_blank"
                                    class="btn btn-outline-light"
                                >
                                    GitHub
                                </a>

                                <a
                                    href={project.demo}
                                    target="_blank"
                                    class="btn btn-primary"
                                >
                                    Ver aplicación
                                </a>

                            </div>

                        </div>

                    </div>

                </div>

            </article>

        ))
    }

</section>

<section class="about-me py-5" id="about-me">

  <h2 class="fw-bold text-light mb-4">
    Sobre mí
  </h2>

  <p class="text-light about-text">
    Soy desarrollador de software con más de un año de experiencia en el
    desarrollo de aplicaciones web y APIs utilizando tecnologías como C#,
    .NET, ASP.NET MVC, PostgreSQL y SQL Server. Me apasiona aprender nuevas
    herramientas, escribir código limpio y crear soluciones que aporten valor
    a las personas y a las empresas.
  </p>

  <p class="text-light about-text">
    Actualmente continúo fortaleciendo mis conocimientos en desarrollo
    Backend, arquitectura de software y tecnologías modernas para construir
    aplicaciones escalables y de alto rendimiento. También disfruto aprender
    sobre Frontend para comprender el desarrollo web de manera integral.
  </p>

</section>

<section class="education py-5" id="education">

    <h2 class="fw-bold text-light mb-5">
        Educación y certificaciones
    </h2>

    {
        education.map((item) => (

            <article class="card bg-dark border-secondary text-light shadow mb-4">

                <div class="row g-0 align-items-center">

                    <div class="col-12">

                        <div class="card-body">

                            <small class="text-secondary">
                                {item.period}
                            </small>

                            <h4 class="mt-2">
                                {item.title}
                            </h4>

                            <h6 class="text-primary mb-3">
                                {item.institution}
                            </h6>

                            <p class="mb-0">
                                {item.description}
                            </p>

                        </div>

                    </div>

                </div>

            </article>

        ))
    }

</section>


<style>
.timeline{
  position:relative;
  padding-left:40px;
}


.timeline::before{
  content:"";
  position:absolute;
  left:7px;
  top:0;
  bottom:0;
  width:2px;
  background:#0d6efd; 
}

.timeline-item{
  position:relative;
}

.dot{
  position:absolute;
  left:-40px;
  top:22px;

  width:16px;
  height:16px;

  background:#0d6efd;
  border-radius:50%;
  border:3px solid #212529;
}

.card{
  border-radius:14px;
  transition:.25s;
}

.card:hover{
  transform:translateY(-4px);
}

.card-body p{
  line-height:1.7;
}

@media (max-width:768px){

  .timeline{
    padding-left:28px;
  }

  .dot{
    left:-28px;
  }

}

.projects{
    padding:6rem 0;
}

.project-image{
    width:100%;
    height:260px;
    object-fit:cover;
    border-radius:.5rem 0 0 .5rem;
}

.card{
    border-radius:16px;
    overflow:hidden;
    transition:.25s;
}

.card:hover{
    transform:translateY(-5px);
}

.card-text{
    line-height:1.8;
}

@media (max-width:992px){

    .project-image{
        height:220px;
        border-radius:.5rem .5rem 0 0;
    }

}

.about-me{
    padding: 6rem 0;
}

.about-text{
    max-width: 850px;
    font-size: 1.05rem;
    line-height: 1.9;
    color: #d1d5db;
}

.education{
    padding:6rem 0;
}

.education-image{
    width:100%;
    height:180px;
    object-fit:contain;
    padding:20px;
}

.card{
    border-radius:16px;
    overflow:hidden;
    transition:.3s;
}

.card:hover{
    transform:translateY(-5px);
}

.card-body p{
    line-height:1.8;
}

@media(max-width:768px){

    .education-image{
        height:140px;
    }

}
</style>